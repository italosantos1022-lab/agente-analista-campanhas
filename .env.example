# Copie para `.env` e preencha. NUNCA commite o `.env` (já está no .gitignore).
# As fases iniciais (ingestão/análise) rodam sem nada disto preenchido.

# --- Caminhos (opcional; há defaults sensatos) ---
# INPUT_CSV=data/dados-campanhas.csv
# OUTPUT_DIR=output

# --- Logging ---
LOG_LEVEL=INFO

# --- LLM (Fase 3) ---
ANTHROPIC_API_KEY=
LLM_MODEL_DIAGNOSTICO=claude-sonnet-4-6
LLM_MODEL_REFERENCIA=claude-haiku-4-5-20251001
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=3

# --- Notificação: Telegram (Fase 5) ---
# Ligue o canal e preencha os 2 campos. O dispatcher só envia se ENABLED=true.
#   BOT_TOKEN: crie um bot com @BotFather e copie o token.
#   CHAT_ID  : seu id/grupo (fale com o bot e veja em
#              https://api.telegram.org/bot<TOKEN>/getUpdates).
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notificação: Email (Fase 5) ---
# Ligue o canal e preencha remetente/destinatário (EMAIL_TO aceita vários,
# separados por vírgula). O transporte é escolhido nesta ordem:
#   1) RESEND_API_KEY definido  -> envia via Resend (recomendado);
#   2) senão, SMTP_HOST definido -> envia via SMTP (fallback).
EMAIL_ENABLED=false
EMAIL_FROM=
EMAIL_TO=
# Opção 1 — Resend (https://resend.com, chave começa com "re_"):
RESEND_API_KEY=
# Opção 2 — Fallback SMTP (ex.: smtp.gmail.com / senha de app):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
