# Copie para `.env` e preencha. NUNCA commite o `.env` (já está no .gitignore).
# As fases iniciais (ingestão/análise) rodam sem nada disto preenchido.

# --- Caminhos (opcional; há defaults sensatos) ---
# INPUT_CSV=data/dados-campanhas.csv
# OUTPUT_DIR=output

# --- Logging ---
LOG_LEVEL=INFO

# --- LLM (Fase 3) ---
ANTHROPIC_API_KEY=
LLM_MODEL_DIAGNOSTICO=claude-sonnet-4-6
LLM_MODEL_REFERENCIA=claude-haiku-4-5-20251001
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=3

# --- Notificação: Telegram (Fase 5) ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notificação: Email via Resend (Fase 5) ---
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TO=

# --- Fallback SMTP (opcional, documentado) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
